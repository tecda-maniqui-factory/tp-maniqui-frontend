{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/main.tsx"],
  "out": "docs/technical-reference",
  "name": "TP Maniquí Frontend - Referencia Técnica",
  "includeVersion": true,
  "excludeExternals": true,
  "excludeInternal": true,
  "cleanOutputDir": true,
  "githubPages": false,
  "externalSymbolLinkMappings": {
    "@types/react": {
      "Component": "https://react.dev/reference/react/Component",
      "Component.render": "https://react.dev/reference/react/Component#render",
      "Component.setState": "https://react.dev/reference/react/Component#setstate",
      "PureComponent": "https://react.dev/reference/react/PureComponent"
    }
  }
}
